# ── Required ─────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://user:password@localhost:5432/eyeradar

# ── Keycloak Authentication ──────────────────────────────────────────────────
KEYCLOAK_ISSUER=http://localhost:8080/realms/game_dev
# OR set these two:
# KEYCLOAK_URL=http://localhost:8080
# KEYCLOAK_REALM=game_dev
KEYCLOAK_CLIENT_ID=eyeradar-frontend

# Keycloak Admin (for child account provisioning)
KEYCLOAK_ADMIN_CLIENT_ID=admin-cli
KEYCLOAK_ADMIN_CLIENT_SECRET=

# ── CORS ─────────────────────────────────────────────────────────────────────
CORS_ORIGINS=http://localhost:3000

# ── LLM / AI Content Generation ─────────────────────────────────────────────
# For cloud (OpenAI-compatible):
# LLM_PROVIDER=openai
# OPENAI_API_KEY=sk-...
# OPENAI_BASE_URL=https://api.openai.com/v1
# OPENAI_HEAVY_MODEL=gpt-4o
# OPENAI_LIGHT_MODEL=gpt-4o-mini

# For local (Ollama):
# LLM_PROVIDER=ollama
# OLLAMA_BASE_URL=http://localhost:11434
# OLLAMA_HEAVY_MODEL=qwen3-vl:8b
# OLLAMA_LIGHT_MODEL=qwen3-vl:4b

# ── Stripe Billing ───────────────────────────────────────────────────────────
# STRIPE_SECRET_KEY=sk_test_...
# STRIPE_WEBHOOK_SECRET=whsec_...
# STRIPE_PRICE_PARENT_MONTHLY=price_...
# STRIPE_PRICE_EXTRA_CHILD=price_...

# ── Email (SMTP for password reset) ─────────────────────────────────────────
# SMTP_HOST=smtp.example.com
# SMTP_PORT=587
# SMTP_USER=
# SMTP_PASSWORD=
# SMTP_FROM_EMAIL=noreply@eyeradar.app

# ── Application ──────────────────────────────────────────────────────────────
APP_BASE_URL=http://localhost:8000
FRONTEND_URL=http://localhost:3000
AUTH_SECRET=change-me-in-production
ONBOARDING_ENCRYPTION_KEY=

# ── Logging ──────────────────────────────────────────────────────────────────
LOG_LEVEL=INFO

# ── Server ───────────────────────────────────────────────────────────────────
PORT=8000
